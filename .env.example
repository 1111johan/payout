# Local API authentication (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
API_KEY=
HOST=127.0.0.1
PORT=8080

# Start in static sandbox mode.
SP_API_MODE=sandbox
SP_API_SANDBOX_ENDPOINT_EU=https://sandbox.sellingpartnerapi-eu.amazon.com
SP_API_PRODUCTION_ENDPOINT_EU=https://sellingpartnerapi-eu.amazon.com

SANDBOX_LWA_CLIENT_ID=
SANDBOX_LWA_CLIENT_SECRET=
SANDBOX_LWA_REFRESH_TOKEN=

PRODUCTION_LWA_CLIENT_ID=
PRODUCTION_LWA_CLIENT_SECRET=
PRODUCTION_LWA_REFRESH_TOKEN=

# All four settings must be changed intentionally before any real payout POST.
DRY_RUN=true
ALLOW_PRODUCTION=false
ALLOW_PAYOUT_POST=false
ALLOW_SANDBOX_POST=false

# Daily scheduler. Real automatic payouts also require an explicit site allowlist.
TIMEZONE=Asia/Shanghai
SCHEDULER_ENABLED=true
SCHEDULER_POLL_SECONDS=60
AUTO_PAYOUT_MARKETPLACES=

# Read-only Finances API ledger synchronization.
FINANCE_SYNC_ENABLED=true
FINANCE_SYNC_INTERVAL_SECONDS=21600
FINANCE_SYNC_DAYS=180

DATABASE_PATH=data/payouts.sqlite3
